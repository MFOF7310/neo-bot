# ─────────────────────────────────────────────
#  NEO Bot — configuration / configuration du bot
#  Copy to .env / Copier vers .env : cp config.env.example .env
# ─────────────────────────────────────────────

# Discord application credentials (https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here

# Optional: register commands to a single guild instantly (dev).
# Leave empty to register globally (may take up to 1h to propagate).
# Optionnel : enregistre les commandes sur un seul serveur (dev, instantané).
GUILD_ID=

# Health-check HTTP port (PM2 / uptime monitors)
PORT=5003

# Path to the SQLite database (created automatically if missing)
# Chemin de la base SQLite (créée automatiquement si absente)
DB_PATH=./data/afriquiz.sqlite
